{
  "name": "@crawlora-org/sdk",
  "version": "1.25.0-sdk.1",
  "description": "JavaScript and TypeScript SDK for the public Crawlora API.",
  "keywords": [
    "crawlora",
    "crawlora-sdk",
    "sdk",
    "api-client",
    "rest-api-client",
    "typescript",
    "javascript",
    "node",
    "nodejs",
    "fetch",
    "web-scraping",
    "web-scraping-api",
    "scraping-api",
    "data-extraction",
    "web-data",
    "crawler",
    "automation",
    "search-api",
    "serp-api",
    "public-data",
    "marketplace-data",
    "media-data",
    "maps-data",
    "finance-data"
  ],
  "homepage": "https://crawlora.net",
  "bugs": {
    "url": "https://github.com/Crawlora-org/crawlora-typescript-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Crawlora-org/crawlora-typescript-sdk.git"
  },
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "docs",
    "examples",
    "src",
    "openapi/public.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "example:bing-search": "node examples/bing-search.mjs",
    "example:youtube-transcript": "node examples/youtube-transcript.mjs",
    "generate": "python3 scripts/generate.py",
    "pack:check": "npm pack --dry-run",
    "smoke:live": "npm run example:bing-search && npm run example:youtube-transcript",
    "typecheck": "npx --yes -p typescript@5.5.4 tsc --noEmit --target ES2022 --module NodeNext --moduleResolution NodeNext --strict src/index.d.ts src/types.d.ts test/types-usage.ts",
    "test": "node --test test/*.test.mjs"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
